# Copy this file to `.env` in the same folder as server.js (e.g. ~/zimo-usage/.env).
# `.env` is gitignored — create it on each machine that runs the app.

# Required for WhatsApp notifications (group JID ends with @g.us)
WHATSAPP_GROUP_JID=

# Set to 1 while running `node pair-whatsapp.mjs` so the service does not use Baileys at the same time.
# Remove or set to 0 when done pairing.
# WHATSAPP_DISABLE=1

# Optional: override Baileys auth directory (default: ./data/whatsapp-auth)
# WHATSAPP_AUTH_DIR=
